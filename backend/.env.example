# Copy to .env for local dev. Never commit real secrets.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=postgres://postgres:postgres@db:5432/resume_analyzer
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Object storage (MinIO in dev)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=resumes
S3_REGION=us-east-1

# LLM provider — default to the offline FakeClient until M3 wires real keys.
LLM_PROVIDER=fake
LLM_MODEL_FAST=fake-fast
LLM_MODEL_STRONG=fake-strong
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

CORS_ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
