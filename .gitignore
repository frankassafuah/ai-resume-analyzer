# ─── Python / Django ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
staticfiles/
media/
*.log
db.sqlite3

# Test / lint / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Celery
celerybeat-schedule
celerybeat.pid

# ─── Environment / secrets ──────────────────────────────────────────
