.env
.env.*
*.local
!.env.example
!*.env.example

# ─── Node / Nuxt (frontend) ─────────────────────────────────────────
node_modules/
.nuxt/
.output/
.nitro/
.cache/
.data/
dist/
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Local-only notes / design docs (not committed) ─────────────────
sessions/
docs/

# ─── OS / editor ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
